# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
dist/
build/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# ── PyTorch / model artifacts ────────────────────────────────────────
*.pt
*.pth
*.ckpt
checkpoints/
saved_models/

# ── Jupyter ───────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Datasets ─────────────────────────────────────────────────────────
data/
datasets/
*.csv
*.gz
*.zip
*.tar
*.tar.gz
